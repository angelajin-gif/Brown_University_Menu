# App
APP_NAME=Personalized Canteen Assistant Backend
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# Strict CORS (comma-separated list)
# Cloudflare Pages example: https://<project>.pages.dev
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.pages.dev,https://your-domain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With
CORS_ALLOW_CREDENTIALS=true

# Supabase Postgres (must be direct DB connection string)
# Example: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?sslmode=require
SUPABASE_DB_URL=
# Supabase official Python SDK (required for menu sync upsert)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT_SECONDS=30

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_HTTP_REFERER=https://your-frontend.pages.dev
OPENROUTER_TITLE=canteen-ai-backend

# RAG
RAG_TOP_K=6
RAG_KEYWORD_TOP_K=6
EMBEDDING_DIMENSIONS=1536
DEFAULT_LANG=zh

# Brown menu sync
BROWN_MENU_API_URL=https://esb-level1.brown.edu/services/oit/sys/brown-dining/v1/menus
MENU_SYNC_TIMEZONE=America/New_York
MENU_SYNC_BATCH_SIZE=300
MENU_SYNC_ONLY_TODAY=true
